# * Application metadata
# APP_NAME=my-service
# APP_VERSION=0.1.0
# APP_ENV=development

# * server
# SERVER_SHUTDOWN-TIMEOUT=30s

# * HTTP server
# SERVER_HTTP-PORT=8080
# SERVER_HTTP-READ-HEADER-TIMEOUT=5s
# SERVER_HTTP-READ-TIMEOUT=15s
# SERVER_HTTP-WRITE-TIMEOUT=30s
# SERVER_HTTP-IDLE-TIMEOUT=120s
# SERVER_HTTP-MAX-HEADER-BYTES=1048576

# * CORS (slice values not supported via env; use config file instead)
# SERVER_HTTP-CORS-ALLOWED-ORIGINS=https://example.com

# * gRPC server
# SERVER_GRPC-PORT=9090

# * Logging
# LOGGING_LEVEL=info
# LOGGING_FORMAT=json

# * Telemetry (leave empty to disable trace exporting)
# TELEMETRY_OTLP-ENDPOINT=localhost:4317
